# Celery (merge into docker/env/.env.app for FastAPI, or use as a snippet for a future celery-worker service).
# Broker / backend hostnames must match Docker Compose service names when the worker runs *inside* the stack
# (rabbitmq, redis). Use localhost when running Celery from the host with ports published (see docker/README.md).

# --- RabbitMQ (see docker/env/.env.rabbitmq for RABBITMQ_DEFAULT_USER / PASS / VHOST) ---
# Format: amqp://USER:PASSWORD@HOST:5672/VHOST
CELERY_BROKER_URL=amqp://minirag_user:minirag_rabbitmq_2222@rabbitmq:5672/minirag_vhost

# --- Redis (password must match REDIS_PASSWORD in docker/env/.env.redis and compose default) ---
# Format: redis://:PASSWORD@HOST:6379/DB_INDEX
CELERY_RESULT_BACKEND=redis://:minirag_redis_2222@redis:6379/0

# --- Celery tuning (optional; defaults also exist in helpers/config.py) ---
CELERY_TASK_SERIALIZER=json
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_CONCURRENCY=2
