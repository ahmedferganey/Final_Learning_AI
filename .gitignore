# Keep .gitkeep files
!**/.gitkeep

# Python
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
dist/
build/
.ipynb_checkpoints/

# Virtual environments
**/.venv/
**/venv/
**/env/
**/ENV/
**/.backend/

# Env files
**/.env
**/.env.*
!**/.env.example

# IDEs
**/.vscode/
**/.idea/

# Node / React
**/node_modules/
**/dist/
**/build/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# System files
**/.DS_Store

# Alembic compiled files
**/alembic/versions/*.pyc
**/alembic/versions/*.pyo

# Project-specific ignores
